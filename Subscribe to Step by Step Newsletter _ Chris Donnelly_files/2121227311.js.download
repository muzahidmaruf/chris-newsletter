_swtjsslh",text:"<p>Would you be interested in hearing about exclusive in person mastermind events that I would be running?</p>",syncTo:null,options:[{id:"rqo_700v8x6x",label:"<p>Yes</p>",scores:[],segmentId:"seg_3h45ddeu",conditions:{}},{id:"rqo_o9snynut",label:"<p>No</p>",scores:[],segmentId:"seg_mqw5gf2y",conditions:{}}],inputType:null,isQuestion:!0,dimensionId:"dim_bl53nyiu",displayType:"buttons",syncToField:null,otherOptions:{enabled:!1,inputType:"textarea",nextPrompt:"Next",otherLabel:"Other",inputPrompt:"Please share more",inputPlaceholder:""},displayOptions:{},isRandomizingOptionsOrder:!1},{id:"raq_t03iygmb",text:"<p>Where did you first hear about me?</p>",syncTo:null,options:[{id:"rqo_hlsae28s",label:"<p>LinkedIn</p>",scores:[],segmentId:"seg_944zd40v",conditions:{}},{id:"rqo_76awimi1",label:"Instagram",scores:[],segmentId:"seg_ctxryb0f",conditions:{}},{id:"rqo_ntv1prfx",label:"Facebook",scores:[],segmentId:"seg_uragpfww",conditions:{}},{id:"rqo_gtxp02ug",label:"<p>YouTube</p>",scores:[],segmentId:"seg_l0c5w09m",conditions:{}},{id:"rqo_r5ha3uqi",label:"<p>TikTok</p>",scores:[],segmentId:"seg_erjavetl",conditions:{}},{id:"rqo_71iq9c0z",label:"<p>Wake Up Podcast</p>",scores:[],segmentId:"seg_7pzbbrhf",conditions:{}},{id:"rqo_mranmuz5",label:"<p>From a friend / colleague / family member</p>",scores:[],segmentId:"seg_i52xr6k0",conditions:{}},{id:"rqo_78n01r6s",label:"INT_OTHER",scores:[],segmentId:"seg_kbu8wt36",conditions:{}}],inputType:null,isQuestion:!0,dimensionId:"dim_ichd5fbh",displayType:"buttons",syncToField:null,otherOptions:{enabled:!0,inputType:"input",nextPrompt:"Next",otherLabel:"Other",inputPrompt:"<p>Where did you hear about me?</p>",inputPlaceholder:""},displayOptions:{},isRandomizingOptionsOrder:!1},{id:"raq_g8b08lf3",text:"<p>Last question - totally optional! <br><br>Can you describe in 1 - 2 sentences how you think I can best help you to succeed with your goals? Let me know and I will try my hardest to do just that!</p>",syncTo:null,options:[