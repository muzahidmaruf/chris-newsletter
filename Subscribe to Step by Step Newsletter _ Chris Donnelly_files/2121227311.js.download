.iti__globe {
  background-image: var(--iti-path-globe-1x);
  background-size: contain;
  background-position: right;
  box-shadow: none;
  height: 19px;
}

@media (min-resolution: 2x) {
  .iti__flag {
    background-image: var(--iti-path-flags-2x);
  }
  .iti__globe {
    background-image: var(--iti-path-globe-2x);
  }
}

.iti.iti--allow-dropdown.iti--show-flags.iti--inline-dropdown .iti__selected-country-primary {
  transition: none 0.2s cubic-bezier(0.17, 1.33, 0.43, 1);
}

.iti.iti--allow-dropdown.iti--show-flags.iti--inline-dropdown
  input.iti__tel-input:focus
  ~ div
  button
  .iti__selected-country-primary {
  transform: translateY(5px) !important;
}

.iti__country-container {
  display: none;
}

.rm-phone-focused .iti__country-container {
  display: block;
}

.rm-phone-focused:has(input:focus),
.rm-phone-focused:has(input:not(:placeholder-shown)) {
  .iti__country-container {
    margin-top: 10px;
  }
}
`,qg="",zg={goals:[],phrases:[{id:"phr_w1hyy46f",map:{seg_0od6wn97:"reach your ideal audience",seg_p85v638h:"manage your content creation workflow",seg_rs53cmje:"turn your followers into paying customers",seg_vp2szrf1:"boost your audience engagement"},fallbackText:"address this challenge?",segmentGroupId:"dim_q42j7s1o"},{id:"phr_c9prir5j",map:{seg_0od6wn97:"to solve your audience targeting challenge?",seg_p85v638h:"to solve your content creation challenge?",seg_rs53cmje:"to solve your conversion challenge?",seg_vp2szrf1:"to solve your engagement challenge?"},fallbackText:"to solve your growth challenge?",segmentGroupId:"dim_q42j7s1o"},{id:"phr_fgalik3n",map:{seg_gaf90em9:"looking to start?",seg_xt2xksao:""},fallbackText:"running?",segmentGroupId:"dim_mrsry7bq"},{id:"phr_fispcpub",map:{seg_cz71bh2u:"your content business",seg_jka5lzvr:"your tech startup",seg_w7i8n8to:"your service business",seg_y00nkgu9:"your e-commerce brand"},fallbackText:"your business",segmentGroupId:"dim_jv2gax6d"},{id:"phr_ebcbl3a4",map:{seg_aamzoig0:"your scaling challenges",seg_kvxnq0ii:"your talent and hiring challenges",seg_loqczsdp:"your revenue growth challenges",seg_loxsat7a:"your operational challenges"},fallbackText:"your challenges",segmentGroupId:"dim_dnqyyuqe"},{id:"phr_n800ihdw",map:{seg_kp2j8q69:"would",seg_loc04249:"would",seg_z3yo362s:"would"},fallbackText:"does",segmentGroupId:"dim_daa2r5eo"},{id:"phr_y1gaiygw",map:{seg_f5fzb6le:"side hustle"},fallbackText:"business",segmentGroupId:"dim_2xg84yj3"},{id:"phr_9mn6kauy",map:{seg_fkcmtuph:"haven't you started"},fallbackText:"aren't you full time on",segmentGroupId:"dim_2xg84yj3"},{id:"phr_qhhwwqzl",map:{seg_eir5q44e:"I'm looking forward to helping you do A",seg_kmcf8ugx:"I'm looking forward to helping you do B",seg_o3xm4t3u:"I'm looking forward to helping you do C"},fallbackText:"Thank you!",segmentGroupId:"dim_6p4hyq8e"},{id:"phr_m492l57k",map:{seg_72qu5kbw:"Running the whole show yourself? I get it. At the start of 2024, I was solo too. Now I\u2019ve scaled to 8-figures with a team of five - and my personal brand was the unlock. If you want to grow yours and scale smarter, check out The Creator Accelerator below. Otherwise, I\u2019ll see you in the next Step by Step.",seg_eir5q44e:"Thanks for sharing. I get it - you haven\u2019t started yet. But building your personal brand now gives you a huge head start. It grows your network, builds confidence, and puts you on the radar - even before you\u2019ve got your big idea. That\u2019s exactly what we help people do inside the Creator Accelerator. If you're curious, check it out below. Otherwise, I\u2019ll see you in the next Step by Step.",seg_kmcf8ugx:"Running a business shouldn\u2019t feel like it\u2019s running you. When I built Verb, the personal brand piece gave me an edge - it helped me land clients like Bugatti and Aston Martin. Now I help other business owners do the same inside the Creator Accelerator. Check it out below if you\u2019re curious. Otherwise, I\u2019ll see you in the next Step by Step.",seg_o3xm4t3u:"You\u2019ve already done what 99% of people never will - started. Now it\u2019s about turning that spark into something that gives you freedom. Building my personal brand was the unlock that helped me grow faster, land dream clients, and eventually exit. Now I help others do the same inside the Creator Accelerator. If you want to see how, check it out below. Otherwise - see you in the next Step by Step."},fallbackText:"I will use this information to try and help you as much as I can, speak soon.",segmentGroupId:"dim_6p4hyq8e"}],teamPid:2121227311,version:"2024-01-01",rightAsk:{questions:[{id:"raq_xxlkciht",text:"How many people are on your team?",syncTo:null,options:[{id:"rqo_1hvvliq3",label:"2-5 people",scores:[],segmentId:"seg_y1tz8l4l",conditions:{}},{id:"rqo_wk6p724u",label:"6-15 people",scores:[],segmentId:"seg_rtzsoli9",conditions:{}},{id:"rqo_o8n19hui",label:"16-50 people",scores:[],segmentId:"seg_9b7xbq2y",conditions:{}},